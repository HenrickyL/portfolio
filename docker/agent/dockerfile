FROM node:22-slim

WORKDIR /workspace

# dependências básicas
RUN apt-get update && apt-get install -y \
    git \
    curl \
    bash \
    python3 \
    build-essential

# dependências do projeto
COPY package*.json ./
RUN npm ci || npm install

# Codex CLI
RUN npm install -g @openai/codex

# usuário não-root
RUN useradd -ms /bin/bash agent

# permissões
RUN chown -R agent:agent /workspace

USER agent

CMD ["sh"]